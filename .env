# =============================================================
#  ThreatHunter Pro — Environment Configuration
#  Copy this file to .env and update values before running
# =============================================================

# --- Elasticsearch ---
ELASTIC_PASSWORD=ThreatHunter@2024
KIBANA_PASSWORD=ThreatHunter@2024

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_NETWORK_FLOWS=network-flows
KAFKA_TOPIC_WINDOWS_EVENTS=windows-events
KAFKA_TOPIC_ALERTS=threat-alerts

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- ML Engine ---
MODEL_PATH=./data/models
ANOMALY_THRESHOLD_NETWORK=0.85
ANOMALY_THRESHOLD_WINDOWS=0.80
BATCH_SIZE=512

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
SECRET_KEY=change-me-in-production-use-secrets-manager

# --- Alert Engine ---
ALERT_COOLDOWN_SECONDS=60
MAX_ALERTS_PER_MINUTE=100
